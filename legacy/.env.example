# ── Runtime ────────────────────────────────────────
NODE_ENV=development
PORT=10000
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────
DATABASE_URL=postgresql://ngo:ngo@localhost:5432/ngo_platform
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) ───────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=ngo-platform

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Resend (email provider) ───────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=NGO Platform

# ── SendGrid (legacy, optional) ──────────────────
# SENDGRID_API_KEY=SG.
# SENDGRID_FROM_EMAIL=noreply@example.org
# SENDGRID_FROM_NAME=NGO Platform

# ── Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Media storage (S3 / R2) ───────────────────────
S3_BUCKET=ngo-media
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ── Rate limiting ─────────────────────────────────
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=10
