{
  "name": "ruralnexus-cms",
  "version": "0.1.0",
  "description": "RuralNexus NGO content backend — Payload CMS 3 on Next.js, deployed to Render with Supabase Postgres",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/publications.ts",
    "seed:programs": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/programs.ts",
    "seed:news-events": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/news-events.ts",
    "seed:team": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/team.ts",
    "seed:stories": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/stories.ts",
    "seed:metrics": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/impact-metrics.ts",
    "seed:testimonials": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/testimonials.ts",
    "seed:partners": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/partners.ts",
    "seed:researchgate": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/researchgate-publications.ts",
    "seed:site-settings": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/site-settings.ts",
    "seed:homepage": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/homepage.ts",
    "seed:contact-page": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/contact-page.ts",
    "seed:all": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env src/seed/index.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-s3": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.3",
    "payload": "^3.83.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "sharp": "0.34.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
